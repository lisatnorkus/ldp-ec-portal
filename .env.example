# Supabase — `ldp-ec-portal` project
# Values pulled from Supabase dashboard → Project Settings → API.
# Publishable key is safe in the browser; DO NOT commit the service_role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Passphrase auth (v2.0 initial).
# Retired when OAuth lands post-testing.
NEXT_PUBLIC_AUTH_PASSPHRASE=

# kypolitics — read-only source for 629 JeffCo precincts.
# Used by /my-ld and Canvass Tools. SELECT only from this project.
NEXT_PUBLIC_KYPOLITICS_SUPABASE_URL=
NEXT_PUBLIC_KYPOLITICS_PUBLISHABLE_KEY=
